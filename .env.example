# Copy to .env and fill in your key:  cp .env.example .env
# .env is gitignored; .env.example is the committed template.

# ---- OpenRouter (OpenAI-compatible gateway) — OPTIONAL ----
# Current prototype works without this; use it when adding LLM/vision fallback.
# Create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# OpenAI-compatible base URL for OpenRouter. Rarely changed.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- Model (swap here without touching code) ----
LLM_MODEL=openai/gpt-5.5
# LLM_TEMPERATURE=0

# Optional OpenRouter attribution headers (visible in your OpenRouter dashboard)
OPENROUTER_APP_URL=http://localhost:8000
OPENROUTER_APP_TITLE=Agentic Tax-Filing Assistant

# ---- Server ----
PORT=8000
PYTHONPATH=src

# ---- Observability / traceability (Pillar 4, SPECS §4.7) ----
# TRACE_ENABLED: emit structured per-turn traces (input -> model msg -> tool
#   calls/args -> results -> computed lines -> next phase) to stdout + /trace.
# LOG_LEVEL: DEBUG|INFO|WARNING|ERROR.
TRACE_ENABLED=true
LOG_LEVEL=INFO
